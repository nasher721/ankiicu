# Docker Compose (npm run db:up) — port 5432
# DATABASE_URL="postgresql://postgres:postgres@127.0.0.1:5432/ankiicu"

# npm run dev:local (embedded Postgres) — port 5433
# DATABASE_URL="postgresql://postgres:postgres@127.0.0.1:5433/ankiicu"

# Optional: require session login at /login + httpOnly cookie, or Authorization: Bearer <same value>
# APP_API_SECRET="generate-a-long-random-string"

# Optional: set to 1 to include AI rawResponse snippets in 500 JSON (local debugging only)
# DEBUG_AI=
