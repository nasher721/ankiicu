# `npm run build` runs `prisma migrate deploy` — set DATABASE_URL so production schema is applied.
#
# --- Local / Docker (same value for both URL vars)
# DATABASE_URL="postgresql://postgres:postgres@127.0.0.1:5432/ankiicu"
# DIRECT_URL="postgresql://postgres:postgres@127.0.0.1:5432/ankiicu"

# npm run dev:local (embedded Postgres, port 5433)
# DATABASE_URL="postgresql://postgres:postgres@127.0.0.1:5433/ankiicu"
# DIRECT_URL="postgresql://postgres:postgres@127.0.0.1:5433/ankiicu"

# --- Prisma Postgres (https://www.prisma.io/docs/postgres)
# From Prisma Console: Connect → copy pooled + direct strings.
# DATABASE_URL="postgres://USER:PASSWORD@pooled.db.prisma.io:5432/postgres?sslmode=require"
# DIRECT_URL="postgres://USER:PASSWORD@db.prisma.io:5432/postgres?sslmode=require"

# --- Vercel Native Integration (Prisma Postgres)
# Repo root, after `npx vercel login` and `npx vercel link`:
#   npx vercel integration discover prisma
#   npx vercel integration add prisma/prisma-postgres
# Connects the DB to this project and pulls env (map or prefix vars so DATABASE_URL + DIRECT_URL match schema).
# https://vercel.com/docs/integrations/install-an-integration/product-integration

# --- One-command trial DB (24h unless claimed): npm run db:prisma-create
# Quick start: https://www.prisma.io/docs/postgres/npx-create-db

# Optional API gate (production): /login with this value, or Bearer token
# APP_API_SECRET="generate-a-long-random-string"

# Optional max upload size in bytes (default: 15 MiB self-hosted, ~4 MiB when VERCEL=1)
# MAX_UPLOAD_BYTES=15728640

# DEBUG_AI=
